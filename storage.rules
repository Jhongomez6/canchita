rules_version = '2';

// ============================================================================
// CANCHITA — Storage Rules
// ----------------------------------------------------------------------------
// Reglas para:
//   - avatars/                  — fotos de perfil de usuarios (lectura pública)
//   - venues/{venueId}/cover.*  — fotos de portada de sedes (lectura pública)
//   - payment_proofs/{venueId}/{file}  — comprobantes de pago (privado + lifecycle 90d)
//   - venue_payment_qrs/{venueId}/{methodId}.*  — QR de métodos de pago (lectura pública)
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helpers ──────────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    // Lectura segura del user doc — usa .get(field, default) en vez de acceso directo
    // para evitar fallos silenciosos cuando un campo es null o no existe.
    function userData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthed()
        && userData().get('adminType', '') == 'super_admin';
    }

    function isVenueAdmin(venueId) {
      return isAuthed() && (
        userData().get('adminType', '') == 'super_admin'
        || (
          userData().get('adminType', '') == 'location_admin'
          && (venueId in userData().get('assignedLocationIds', []))
        )
      );
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isUnder(maxBytes) {
      return request.resource != null && request.resource.size <= maxBytes;
    }

    // ─── Avatars (perfil de usuario) ──────────────────────────────────────
    // Lectura PÚBLICA — los <img> del navegador no envían token de Firebase Auth,
    // así que isAuthed() falla para img tags. Los avatares ya son públicos por diseño.
    match /avatars/{fileName} {
      allow read: if true;
      // Solo el dueño puede subir su avatar (fileName empieza con su uid).
      allow write: if isAuthed()
        && fileName.matches(request.auth.uid + '.*')
        && isImage()
        && isUnder(2 * 1024 * 1024); // 2 MB
    }

    // ─── Cover image de sede ──────────────────────────────────────────────
    // Lectura PÚBLICA — las portadas se renderizan con <img>/<Image> sin Auth header.
    match /venues/{venueId}/{fileName} {
      allow read: if true;
      // Solo admins del venue suben/reemplazan la foto de portada.
      allow write: if isVenueAdmin(venueId)
        && isImage()
        && isUnder(5 * 1024 * 1024); // 5 MB
    }

    // ─── Payment proofs (comprobantes de abono) ───────────────────────────
    // Path: payment_proofs/{venueId}/{bookingId}_{timestamp}.jpg
    //
    // Lectura: cualquier autenticado. El acceso real está limitado por la URL
    // de download (token-based) que solo está en el doc de booking, que tiene
    // sus propias rules estrictas. Random users no pueden listar el bucket
    // ni enumerar paths (Storage no permite list sin permiso) — solo acceden
    // si tienen la URL completa con token.
    //
    // Escritura: cualquier autenticado con imagen ≤ 500KB. La validación real
    // (dueño del booking, status correcto, intentos restantes) la hace la
    // Cloud Function `uploadPaymentProof` antes de aceptar la URL en el doc.
    // Si un atacante sube un archivo huérfano aquí, queda en Storage sin
    // referencia hasta que lifecycle (90d) lo borre.
    //
    // Lifecycle de 90 días aplicado server-side desde GCS (gcs-lifecycle.json).
    match /payment_proofs/{venueId}/{fileName} {
      allow read: if isAuthed();

      allow create: if isAuthed()
        && isImage()
        && isUnder(500 * 1024); // 500 KB (post-compresión)

      // No permitimos overwrite — cada intento debe usar un timestamp distinto.
      allow update: if false;

      // Delete: cualquier autenticado (el caso común es el lifecycle automático).
      allow delete: if isAuthed();
    }

    // ─── Venue payment QRs (QR de métodos de pago configurados por venue) ─
    // Path: venue_payment_qrs/{venueId}/{paymentMethodId}.jpg
    // Lectura PÚBLICA: los QR se renderizan con <img>/<Image> sin Auth header,
    // y por diseño son públicos (cualquiera con el QR puede pagar al venue).
    // Escritura: cualquier usuario autenticado. La seguridad real está en Firestore:
    // el campo `paymentMethods` (donde queda el qrImageURL) solo lo edita Super Admin
    // por field-level check en firestore.rules. Si un no-admin sube un QR aquí, el
    // archivo queda huérfano (no puede asociarlo a un venue) — sin riesgo de seguridad.
    match /venue_payment_qrs/{venueId}/{fileName} {
      allow read: if true;
      allow write: if isAuthed()
        && isImage()
        && isUnder(500 * 1024); // 500 KB
    }
  }
}
