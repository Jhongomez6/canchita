rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función reutilizable para saber si el usuario es Admin.
    // Soporta el formato antiguo (role: "admin") y el nuevo (roles: ["admin", "player"])
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && (
        userDoc.data.get('role', '') == "admin" || 
        ("admin" in userDoc.data.get('roles', []))
      );
    }

    function isSuperAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.get('adminType', '') == "super_admin";
    }

    function isTeamAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.get('adminType', '') == "team_admin";
    }

    // Verifica si el usuario es location_admin asignado a una location específica
    function isLocationAdminFor(locationId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null
        && userDoc.data.get('adminType', '') == "location_admin"
        && locationId in userDoc.data.get('assignedLocationIds', []);
    }

    // Helper: usuario estuvo en el partido cerrado (post-match review)
    function wasInClosedMatch(matchId, uid) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return m.status == "closed" && uid in m.get('playerUids', []);
    }

    // 🏟️ CANCHAS
    match /locations/{locationId} {

      // 👀 Leer: cualquier usuario autenticado
      allow read: if request.auth != null;

      // ➕ Crear: solo super admins
      allow create: if request.auth != null
        && isSuperAdmin()
        && request.resource.data.createdBy == request.auth.uid;

      // ✏️ Update: solo super admins
      allow update: if request.auth != null
        && isSuperAdmin();

      // ❌ Delete: nadie (por ahora)aaqPa
      allow delete: if false;
    }

  /* =========================
       👤 USUARIOS - CORREGIDO
    ========================= */
    match /users/{userId} {
      // ✅ Leer: cualquier usuario autenticado puede leer cualquier perfil
      // (la FIFA Card pública solo muestra datos de gameplay, nunca email/teléfono)
      allow read: if request.auth != null;
 
      // Crear: solo el propio usuario
      allow create: if request.auth != null && request.auth.uid == userId;
 
      // Update: usuario NO puede cambiar su rol/roles ni campos de sistema (XP/kudos/reports/flags),
      // admin puede todo salvo roles/tiers/flags (superadmin only). El cliente SÍ puede escribir
      // `xpOnboardingSeenAt` (flag del modal de onboarding) — por eso NO está en la lista bloqueada.
      // `xpEnabled` está protegido — solo super_admin puede togglear el acceso al feature.
      allow update: if request.auth != null
        && (
          (
            request.auth.uid == userId
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'role', 'roles', 'adminType', 'locationAdminRole', 'assignedLocationIds',
              'kudosSummary', '_reportsSummary',
              'xp', 'xpLevel', 'xpTier', 'xpLastEvent', 'achievements',
              'firstMatchAt', 'earlyConfirmCount', 'reviewCount', 'perfectMonths',
              'xpEnabled', 'worldCupEnabled'
            ]))
          )
          ||
          (
            isAdmin()
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'role', 'roles', 'adminType', 'locationAdminRole', 'assignedLocationIds',
              'kudosSummary', '_reportsSummary',
              'xp', 'xpLevel', 'xpTier', 'xpLastEvent', 'achievements',
              'firstMatchAt', 'earlyConfirmCount', 'reviewCount', 'perfectMonths',
              'xpEnabled', 'worldCupEnabled'
            ]) || isSuperAdmin())
          )
        );
 
      // Delete: el propio usuario o admins
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Auto-anonimización (Habeas Data): el propio usuario puede sobreescribir su doc
      // únicamente si el resultado tiene deleted=true (elimina datos personales)
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.get('deleted', false) == true;
    }

    /* =========================
       ⚽ PARTIDOS
    ========================= */
    match /matches/{matchId} {

      // 👀 Leer documento individual (get): cualquier usuario autenticado
      // El filtrado por tier de admin se hace client-side (igual que list).
      // Nota: list ya permite queries a cualquier usuario autenticado, así que
      // restringir get no aporta seguridad adicional y causaba "missing permissions"
      // cuando isAdmin() evaluaba true por el campo legacy `role` en jugadores.
      allow get: if request.auth != null;

      // 👀 Listar (collection queries): cualquier usuario autenticado puede hacer queries
      // El filtrado fino (isPrivate, tier de admin) se hace client-side
      // Nota: el get rule ya protege el acceso individual a documentos sensibles
      allow list: if request.auth != null;

      // ✍️ Crear: solo admins
      allow create: if request.auth != null
        && isAdmin()
        && request.resource.data.createdBy == request.auth.uid;

      // ✏️ Update
      allow update: if request.auth != null
        && (
          // 👑 Admin global (puede modificar cualquier campo, incluyendo payments)
          isAdmin()
          ||
          // ⚽ Jugador (antes o después del update) — NO puede tocar el mapa payments
          (
            (
              request.auth.uid in resource.data.playerUids
              || request.auth.uid in request.resource.data.playerUids
            )
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['payments'])
          )
        );

      allow delete: if request.auth != null
        && (
          resource.data.createdBy == request.auth.uid
          || isSuperAdmin()
        );
    }

    /* =========================
       💰 BILLETERA
    ========================= */
    match /wallets/{uid} {
      // Leer: solo el propio usuario
      allow read: if request.auth != null && request.auth.uid == uid;
      // Escribir: solo Cloud Functions (admin SDK)
      allow write: if false;
    }

    /* =========================
       💳 TRANSACCIONES WALLET
    ========================= */
    match /wallet_transactions/{txId} {
      // Leer: solo el propio usuario (filtra por uid en el documento)
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      // Escribir: solo Cloud Functions (admin SDK)
      allow write: if false;
    }

    /* =========================
       🎟️ CÓDIGOS DE RECARGA
    ========================= */
    match /topup_codes/{code} {
      // Lectura y escritura solo via Cloud Functions (admin SDK)
      allow read, write: if false;
    }

    /* =========================
       📢 FEEDBACK
    ========================= */
    match /feedback/{feedbackId} {
      // Leer: solo admins
      allow read: if request.auth != null && isAdmin();
      
      // Crear: cualquier usuario autenticado puede crear su propio feedback
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update/Delete: Nadie puede (o administrado desde panel de GCP)
      allow update, delete: if false;
    }

    /* =========================
       🔔 NOTIFICACIONES IN-APP
    ========================= */
    match /notifications/{userId}/items/{notifId} {
      // Leer: solo el propio usuario
      allow read: if request.auth != null && request.auth.uid == userId;

      // Update: solo el propio usuario (para marcar como leída)
      allow update: if request.auth != null && request.auth.uid == userId;

      // Crear: Cloud Functions (admin SDK) o super_admin (para notificaciones de aplicación)
      allow create: if request.auth != null && isSuperAdmin();

      // Borrar: solo Cloud Functions (admin SDK)
      allow delete: if false;
    }

    /* =========================
       📝 SOLICITUDES TEAM ADMIN
    ========================= */
    match /applications/{applicantUid} {
      // Leer propia solicitud: el propio usuario / Leer cualquier solicitud individual: super_admin
      allow get: if request.auth != null && (request.auth.uid == applicantUid || isSuperAdmin());

      // Leer todas (queries): solo super_admin
      allow list: if request.auth != null && isSuperAdmin();

      // Crear (primer submit): solo el propio usuario con status "pending"
      allow create: if request.auth != null
        && request.auth.uid == applicantUid
        && request.resource.data.status == "pending";

      // Actualizar:
      // - super_admin puede cambiar cualquier campo (aprobación/rechazo)
      // - el propio usuario solo puede re-aplicar: si el doc actual es "rejected"
      //   y el nuevo doc vuelve a "pending" (sin tocar campos de revisión internos)
      allow update: if request.auth != null
        && (
          isSuperAdmin()
          ||
          (
            request.auth.uid == applicantUid
            && resource.data.status == "rejected"
            && request.resource.data.status == "pending"
          )
        );

      // Borrar: nadie (las solicitudes quedan como historial)
      allow delete: if false;
    }

    /* =========================
       🏟️ SEDES (VENUES)
    ========================= */
    match /venues/{venueId} {
      // Leer: cualquier usuario autenticado
      allow read: if request.auth != null;

      // Crear: solo super_admin
      allow create: if request.auth != null && isSuperAdmin();

      // Actualizar:
      //   - Super Admin: cualquier campo
      //   - Location Admin asignado: cualquier campo EXCEPTO paymentMethods
      //     (datos bancarios sensibles, solo Super Admin)
      allow update: if request.auth != null
        && (
          isSuperAdmin()
          || (
            isLocationAdminFor(venueId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentMethods'])
          )
        );

      // Borrar: nadie
      allow delete: if false;

      // Sub-colección: courts
      match /courts/{courtId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));
      }

      // Sub-colección: court_combos
      match /court_combos/{comboId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));
      }

      // Sub-colección: schedules
      match /schedules/{dayOfWeek} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));
      }

      // Sub-colección: blocked_slots
      match /blocked_slots/{slotId} {
        allow read: if request.auth != null;
        // Crear / actualizar (incluye cancelar → status "cancelled"): super o location admin.
        allow create, update: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));
        // Hard-delete permanente: SOLO super admin. Location admin cancela (update status),
        // nunca borra el registro. Cubre el deleteDoc client-side de cancelManualReservation
        // scope "all". El Cloud Function deleteBlockedSlot usa Admin SDK y refuerza el rol en código.
        allow delete: if request.auth != null && isSuperAdmin();
      }

      // Sub-colección: payments — pagos de reservas manuales
      // Solo super_admin o location_admin asignado al venue: contiene info financiera
      // operativa (montos por reserva). Se valida la invariante totalCOP === cash + transfer.
      match /payments/{paymentId} {
        allow read: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));

        allow create: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId))
          && request.resource.data.cashCOP is int
          && request.resource.data.cashCOP >= 0
          && request.resource.data.transferCOP is int
          && request.resource.data.transferCOP >= 0
          && (request.resource.data.cashCOP + request.resource.data.transferCOP) > 0
          && request.resource.data.totalCOP == request.resource.data.cashCOP + request.resource.data.transferCOP
          && request.resource.data.registeredBy == request.auth.uid
          && request.resource.data.date is string
          && request.resource.data.reservationId is string
          && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 200));

        allow update: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId))
          && request.resource.data.cashCOP is int
          && request.resource.data.cashCOP >= 0
          && request.resource.data.transferCOP is int
          && request.resource.data.transferCOP >= 0
          && (request.resource.data.cashCOP + request.resource.data.transferCOP) > 0
          && request.resource.data.totalCOP == request.resource.data.cashCOP + request.resource.data.transferCOP
          // Inmutables: no se puede cambiar reservationId, date, registeredBy
          && request.resource.data.reservationId == resource.data.reservationId
          && request.resource.data.date == resource.data.date
          && request.resource.data.registeredBy == resource.data.registeredBy
          && (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() <= 200));

        allow delete: if request.auth != null
          && (isSuperAdmin() || isLocationAdminFor(venueId));
      }
    }

    /* =========================
       ⭐ POST-MATCH REVIEW
    ========================= */

    match /matchReviews/{reviewId} {
      // Read permisivo: el rating + dimensiones + comentario no son sensibles.
      // Necesario para que el cliente pueda chequear su propio review (puede no existir).
      // Resource-based check fallaba al evaluar resource.data en docs no existentes.
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userUid
        && reviewId == request.resource.data.matchId + "_" + request.auth.uid
        && wasInClosedMatch(request.resource.data.matchId, request.auth.uid)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && (!('comment' in request.resource.data)
            || request.resource.data.comment.size() <= 500);

      allow update: if false; // inmutable
      allow delete: if false;
    }

    match /playerKudos/{kudoId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.giverUid
        && request.resource.data.giverUid != request.resource.data.recipientUid
        && request.resource.data.type in
            ["buen_toque", "goleador", "muralla", "fair_play", "capitan"]
        && wasInClosedMatch(request.resource.data.matchId, request.auth.uid);

      allow update: if false;
      allow delete: if false;
    }

    match /playerReports/{reportId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.reporterUid || isAdmin());

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.reporterUid
        && request.resource.data.reporterUid != request.resource.data.reportedUid
        && request.resource.data.reason in
            ["no_show", "aggressive_behavior", "level_mismatch", "late_no_warning", "other"]
        && (
          request.resource.data.reason != "other"
          || ('comment' in request.resource.data && request.resource.data.comment.size() > 0)
        )
        && (!('comment' in request.resource.data)
            || request.resource.data.comment.size() <= 500)
        && wasInClosedMatch(request.resource.data.matchId, request.auth.uid)
        && request.resource.data.status == "pending";

      allow update: if request.auth != null && isAdmin();
      allow delete: if false;
    }

    match /moderationAlerts/{alertId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false; // solo Cloud Functions
    }

    /* =========================
       ⚡ XP EVENTS (auditoría del sistema de XP)
    ========================= */
    match /xpEvents/{eventId} {
      // Leer: solo el dueño del evento o admin (historial es privado)
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.uid || isAdmin());

      // Escribir: solo Cloud Functions (admin SDK)
      allow write: if false;
    }

    /* =========================
       📅 RESERVAS (BOOKINGS)
    ========================= */
    match /bookings/{bookingId} {
      // Get individual: el dueño de la reserva, super_admin, o location_admin asignado al venue
      allow get: if request.auth != null
        && (
          resource.data.bookedBy == request.auth.uid
          || isSuperAdmin()
          || isLocationAdminFor(resource.data.venueId)
        );

      // List (queries): cualquier usuario autenticado
      // Necesario para getBookingsForDate() que verifica disponibilidad de courts
      // y vista admin "Reservas pendientes" (filtrada por venueId)
      allow list: if request.auth != null;

      // Crear/Actualizar/Borrar: solo Cloud Functions (admin SDK)
      allow create, update, delete: if false;
    }

    /* =========================
       🌍 POLLA MUNDIALISTA 2026
       Ref: docs/POLLA_MUNDIALISTA_SDD.md
    ========================= */

    // Config global de la polla (flag pollEnabled, joinByCodeOpen, etc.).
    // Lectura: todos. Escritura: super_admin (toggles desde el panel admin).
    match /config/worldcup {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin();
    }

    // Código de acceso (secreto): solo el super_admin lo lee/escribe.
    // El canje lo valida la CF redeemWorldCupCode con Admin SDK.
    match /config/worldcupSecret {
      allow read, write: if request.auth != null && isSuperAdmin();
    }

    // Partidos — solo lectura; escritura solo Admin SDK (CF de carga de resultados)
    match /worldcupMatches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Predicciones de los usuarios
    match /worldcupPredictions/{predId} {
      // Lectura: la propia siempre; las ajenas solo si el partido ya arrancó
      // (kickoffMs <= ahora). Así nadie ve predicciones antes del cierre.
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/worldcupMatches/$(resource.data.matchId)).data.kickoffMs <= request.time.toMillis()
      );

      // Crear/editar: solo la propia, solo antes del kickoff, con goles válidos
      // y el id debe ser "{uid}_{matchId}".
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && predId == request.auth.uid + "_" + request.resource.data.matchId
        && request.resource.data.homeGoals is int
        && request.resource.data.awayGoals is int
        && request.resource.data.homeGoals >= 0 && request.resource.data.homeGoals <= 20
        && request.resource.data.awayGoals >= 0 && request.resource.data.awayGoals <= 20
        && get(/databases/$(database)/documents/worldcupMatches/$(request.resource.data.matchId)).data.kickoffMs > request.time.toMillis();

      allow delete: if false;
    }

    // Leaderboard — solo lectura; escritura solo Admin SDK (CF trigger)
    match /worldcupLeaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Predicción de campeón/subcampeón (bonus). Doc id = uid.
    match /worldcupBracketPredictions/{userId} {
      // Lectura: la propia siempre; las ajenas solo tras el deadline.
      allow read: if request.auth != null && (
        userId == request.auth.uid ||
        get(/databases/$(database)/documents/config/worldcup).data.bracketDeadlineMs <= request.time.toMillis()
      );

      // Crear/editar: solo la propia, solo antes del deadline, con equipos válidos y distintos.
      allow create, update: if request.auth != null
        && userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.champion is string
        && request.resource.data.runnerUp is string
        && request.resource.data.champion.size() > 0
        && request.resource.data.runnerUp.size() > 0
        && request.resource.data.champion != request.resource.data.runnerUp
        && get(/databases/$(database)/documents/config/worldcup).data.bracketDeadlineMs > request.time.toMillis();

      allow delete: if false;
    }

  }
}
