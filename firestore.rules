rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función reutilizable para saber si el usuario es Admin.
    // Soporta el formato antiguo (role: "admin") y el nuevo (roles: ["admin", "player"])
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && (
        userDoc.data.get('role', '') == "admin" || 
        ("admin" in userDoc.data.get('roles', []))
      );
    }

    function isSuperAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.get('adminType', '') == "super_admin";
    }

    // 🏟️ CANCHAS
    match /locations/{locationId} {

      // 👀 Leer: cualquier usuario autenticado
      allow read: if request.auth != null;

      // ➕ Crear: solo super admins
      allow create: if request.auth != null
        && isSuperAdmin()
        && request.resource.data.createdBy == request.auth.uid;

      // ✏️ Update: solo super admins
      allow update: if request.auth != null
        && isSuperAdmin();

      // ❌ Delete: nadie (por ahora)aaqPa
      allow delete: if false;
    }

  /* =========================
       👤 USUARIOS - CORREGIDO
    ========================= */
    match /users/{userId} {
      // ✅ Leer: el propio usuario SIEMPRE puede leer su perfil
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ Leer: admins pueden leer cualquier perfil
      allow read: if request.auth != null && isAdmin();
 
      // Crear: solo el propio usuario
      allow create: if request.auth != null && request.auth.uid == userId;
 
      // Update: usuario NO puede cambiar su rol o roles, admin puede todo salvo roles/tiers (superadmin only)
      allow update: if request.auth != null
        && (
          (
            request.auth.uid == userId
            // Verificamos que no intente modificar campos sensibles
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'adminType', 'assignedLocationIds']))
          )
          ||
          (
            isAdmin() 
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'adminType', 'assignedLocationIds']) || isSuperAdmin())
          )
        );
 
      // Delete: el propio usuario o admins
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    /* =========================
       ⚽ PARTIDOS
    ========================= */
    match /matches/{matchId} {

      // 👀 Leer
      allow read: if request.auth != null;

      // ✍️ Crear: solo admins
      allow create: if request.auth != null
        && isAdmin()
        && request.resource.data.createdBy == request.auth.uid;

      // ✏️ Update
      allow update: if request.auth != null
        && (
          // 👑 Admin global
          isAdmin()
          ||
          // ⚽ Jugador (antes o después del update)
          (
            request.auth.uid in resource.data.playerUids
            || request.auth.uid in request.resource.data.playerUids
          )
        );

      allow delete: if false;
    }

    /* =========================
       📢 FEEDBACK
    ========================= */
    match /feedback/{feedbackId} {
      // Leer: solo admins
      allow read: if request.auth != null && isAdmin();
      
      // Crear: cualquier usuario autenticado puede crear su propio feedback
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update/Delete: Nadie puede (o administrado desde panel de GCP)
      allow update, delete: if false;
    }

    /* =========================
       🔔 NOTIFICACIONES IN-APP
    ========================= */
    match /notifications/{userId}/items/{notifId} {
      // Leer: solo el propio usuario
      allow read: if request.auth != null && request.auth.uid == userId;

      // Update: solo el propio usuario (para marcar como leída)
      allow update: if request.auth != null && request.auth.uid == userId;

      // Crear/Borrar: solo Cloud Functions (admin SDK)
      allow create, delete: if false;
    }

  }
}
